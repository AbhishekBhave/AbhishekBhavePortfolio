# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Contact endpoint behavior
CONTACT_RECEIVER_EMAIL=you@your-domain.com
NEXT_PUBLIC_CONTACT_EMAIL=you@your-domain.com
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/30min

# Optional: hCaptcha (enabled only when both are provided)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# Optional: analytics
PLAUSIBLE_DOMAIN=your-domain.com

# Optional: resume download
RESUME_PDF_URL=https://your-cdn.com/resume.pdf